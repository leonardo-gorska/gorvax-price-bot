{
  "name": "gorvax-price-bot",
  "version": "2.0.0",
  "description": "Bot Telegram Enterprise para rastreamento de preços de peças de PC",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "db:backup": "tsx src/scripts/backup.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "telegram",
    "bot",
    "price-tracker",
    "pc-hardware",
    "enterprise"
  ],
  "author": "Gorvax",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@bull-board/api": "^6.20.5",
    "@bull-board/express": "^6.20.5",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@sparticuz/chromium-min": "^143.0.4",
    "@types/cors": "^2.8.19",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "bullmq": "^5.71.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "grammy": "^1.41.1",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "puppeteer-core": "^24.39.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "quickchart-js": "^3.1.3",
    "simple-statistics": "^7.8.9",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}

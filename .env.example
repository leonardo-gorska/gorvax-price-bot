# ============================================
# Bot de Preços — Configuração
# ============================================

# Token do Telegram Bot (obtido via @BotFather)
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI

# Seu Chat ID no Telegram (para receber alertas)
# Descubra enviando /start pro bot e veja o log
TELEGRAM_CHAT_ID=

# Frequência de checagem (cron expression)
# Padrão: a cada 6 horas (4x/dia)
CRON_SCHEDULE=0 */6 * * *

# Nível de log (debug, info, warn, error)
LOG_LEVEL=info

# Rotação de Proxies Avançada (Opcional)
# ============================================
PROXY_URL=http://blabla.proxy.example.com:8080
PROXY_AUTH=username:password

# Redis para BullMQ
REDIS_URL=redis://localhost:6379
